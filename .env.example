# ==========================================
# CONFIGURACIÓN GLOBAL DEL CENTRO DE COMANDO
# (Plantilla de Ejemplo)
# ==========================================

# ------------------------------------------
# 1. Credenciales de Destino (Recurso Confiable)
# ------------------------------------------
RC_USERNAME=tu_usuario_real
RC_PASSWORD=tu_password_real
RC_ENDPOINT=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc
# Cambia a False para enviar los datos reales a producción. Si es True, no consumirá internet y simulará la respuesta.
RC_USE_MOCK=True

# ------------------------------------------
# 2. Configuración de Nuevos Proveedores (Push vs Pull)
# ------------------------------------------
# NOTA ARQUITECTÓNICA: 
# Toda contraseña, token o secreto de las integraciones futuras DEBE colocarse aquí.

# --- INTEGRACIONES PULL (CronJobs) ---
# Si nosotros vamos a buscar los datos (Ej. Samsara, Geotab), 
# necesitamos sus tokens para autenticarnos en sus servidores.
# SAMSARA_API_TOKEN=
# SAMSARA_BASE_URL=https://api.samsara.com/v1
# GEOTAB_USERNAME=
# GEOTAB_PASSWORD=
# GEOTAB_DATABASE=
# GEOTAB_SERVER=my.geotab.com

# --- INTEGRACIONES PUSH (Webhooks) ---
# Si ellos nos envían datos a nuestra URL (Ej. Schmitz), 
# nosotros debemos definir aquí "Claves Secretas" que ellos 
# deberán adjuntar en sus cabeceras (Headers) para dejarlos pasar,
# garantizando así que nadie más pueda inyectar datos falsos.

# Si se activa, Schmitz deberá enviar el Header: "x-api-key"
REQUIRE_SCHMITZ_AUTH=False
SCHMITZ_API_KEY=Schmitz_2026_UltraSecreta
