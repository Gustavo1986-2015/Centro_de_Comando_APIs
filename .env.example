# ==========================================
# CONFIGURACIÓN GLOBAL DEL CENTRO DE COMANDO
# ==========================================
# (Plantilla de Ejemplo)

# ------------------------------------------
# 1. Entorno Global
# ------------------------------------------
# Define el entorno de ejecución (development o production)
APP_ENV=development

# Tamaño del ThreadPool global para operaciones bloqueantes (Zeep, SQLite).
# Reducir en máquinas con poca RAM. Default: 64
THREAD_POOL_SIZE=64

# ------------------------------------------
# 2. Seguridad y Accesos
# ------------------------------------------
# --- Dashboard ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_esto_urgente

# --- Inspector de APIs (Anti-SSRF) ---
# Si INSPECTOR_ALLOW_INSECURE_TLS es False (Recomendado): Verifica estrictamente los certificados HTTPS.
# Si es True: Ignora la validez del certificado HTTPS (¡Vulnerable en producción!).
# Usar True SÓLO contra APIs locales en staging con certificados auto-firmados.
INSPECTOR_ALLOW_INSECURE_TLS=False

# ------------------------------------------
# 3. Seguridad de Credenciales (Envelope Encryption)
# ------------------------------------------
# MASTER_ENC_KEY es la llave maestra para cifrar/descifrar todas las credenciales en SQLite (RC, PUSH, PULL).
# Si está vacía o no existe en el primer arranque, el sistema la autogenerará e inyectará automáticamente en este archivo (.env).
# ¡NUNCA PIERDAS ESTA CLAVE! Si la pierdes, todas las credenciales de proveedores quedarán inaccesibles.
MASTER_ENC_KEY=

# RC_TOKEN_ENC_KEY es para cifrar el token temporal de caché de Recurso Confiable (rc_token_cache_*.json).
# Opcional pero recomendado. Si se omite, se autogenera temporalmente.
RC_TOKEN_ENC_KEY=

# ------------------------------------------
# 4. Proveedores y Credenciales (PULL / PUSH / RC)
# ------------------------------------------
# TODAS las credenciales (Schmitz, Protrack, Recurso Confiable) ahora se gestionan 100% 
# desde la interfaz web (Dashboard -> Configuración de Proveedores) utilizando Envelope Encryption.
# Ya NO se guardan credenciales en este archivo.

# ⚠️ IMPORTANTE (FAIL-SAFE GLOBAL):
# RC_USE_MOCK por defecto controla el fail-safe global. (Aunque puede sobreescribirse por proveedor desde la UI).
# - Si es False (Producción): Ejecuta la petición SOAP real hacia RC.
# - Si es True (Solo Desarrollo): Se SIMULA el envío.
# Aborta en APP_ENV=production si RC_USE_MOCK=True.
RC_USE_MOCK=False

# ------------------------------------------
# 6. Observabilidad (Logs)
# ------------------------------------------
# LOG_LEVEL controla la cantidad y detalle de información. Se puede cambiar en caliente (Hot-Reload).
# - DEBUG: Muestra tráfico de red (XMLs SOAP crudos), polling HTTP, etc.
# - INFO:  Resumen por lote de eventos, reinicios. Mantiene la consola limpia.
# - WARNING / ERROR / CRITICAL: Solo anomalías o fallos.
LOG_LEVEL=INFO

# Días que se conservarán los archivos de log históricos rotativos en la carpeta logs/.
LOG_RETENTION_DAYS=7
