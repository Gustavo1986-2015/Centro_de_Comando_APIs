# ==========================================
# CONFIGURACIÓN GLOBAL DEL CENTRO DE COMANDO
# (Plantilla de Ejemplo)
# ==========================================

# ------------------------------------------
# Entorno
# ------------------------------------------
APP_ENV=development

# ------------------------------------------
# 1. Credenciales de Destino (Recurso Confiable)
# ------------------------------------------
RC_USERNAME=tu_usuario_real
RC_PASSWORD=tu_password_real
RC_ENDPOINT=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc
# ⚠️ IMPORTANTE (FAIL-SAFE): El valor por defecto es False.
# RC_USE_MOCK controla si los datos realmente se envían a Recurso Confiable (RC).
# - Si es False (Recomendado/Producción): El sistema ejecuta la petición SOAP real hacia RC.
#   (OJO: También puedes usar False en APP_ENV=development si quieres hacer pruebas de envío reales).
# - Si es True (Solo Desarrollo): El paso de envío a RC se SIMULA. Los eventos se reciben, 
#   se procesan, pero el envío final por SOAP se omite y se autogenera una respuesta de "éxito" falsa.
#   Esto significa que los datos se consumen y se descartan; NUNCA llegarán a los servidores de RC.
#   Para evitar pérdida silenciosa de datos, el sistema lanzará un RuntimeError si 
#   APP_ENV=production y RC_USE_MOCK=True.
RC_USE_MOCK=False

# ------------------------------------------
# 2. Configuración de Nuevos Proveedores (Push vs Pull)
# ------------------------------------------
# NOTA ARQUITECTÓNICA: 
# Toda contraseña, token o secreto de las integraciones futuras DEBE colocarse aquí.

# --- INTEGRACIONES PULL (CronJobs) ---
# Si nosotros vamos a buscar los datos (Ej. Samsara, Geotab), 
# necesitamos sus tokens para autenticarnos en sus servidores.

# --- Protrack365 (GPS tracking PULL) ---
# URL base: http://api.protrack365.com (misma URL, credenciales distintas por entorno)
# Autenticación: signature = md5(md5(password) + unix_time), token válido 2h
PROTRACK_ACCOUNT_TEST=
PROTRACK_PASSWORD_TEST=
PROTRACK_ACCOUNT_PROD=
PROTRACK_PASSWORD_PROD=
PROTRACK_POLL_INTERVAL_SEC=30

# --- INTEGRACIONES PUSH (Webhooks) ---
# Si ellos nos envían datos a nuestra URL (Ej. Schmitz), 
# nosotros debemos definir aquí "Claves Secretas" que ellos 
# deberán adjuntar en sus cabeceras (Headers) para dejarlos pasar,
# garantizando así que nadie más pueda inyectar datos falsos.

# Si se activa, Schmitz deberá enviar el Header: "x-api-key"
REQUIRE_SCHMITZ_AUTH=False
SCHMITZ_API_KEY=Schmitz_2026_UltraSecreta

# ------------------------------------------
# 3. Seguridad del Dashboard
# ------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_esto_urgente

# ------------------------------------------
# 4. Inspector de APIs (Anti-SSRF)
# ------------------------------------------
# ¿Qué hace esto? El Inspector actúa como un "Postman" interno. 
# Si INSPECTOR_ALLOW_INSECURE_TLS es False (Recomendado): El sistema VERIFICA estrictamente que los 
#   certificados HTTPS de las APIs externas sean válidos (Evita ataques Man-In-The-Middle donde un 
#   atacante podría interceptar y robar tokens o contraseñas en tránsito).
# Si es True: Se ignora la validez del certificado HTTPS (¡Altamente vulnerable en producción!).
# 
# ¿Cuándo ponerlo en True en tu entorno local? 
# SÓLO si estás apuntando el Inspector hacia OTRA API que tienes corriendo en tu red local o 
# staging y que utiliza un certificado HTTPS auto-firmado ("self-signed" / inválido). 
# Si estás probando contra APIs externas reales (ej. Protrack, Samsara), mantenlo en False SIEMPRE.
INSPECTOR_ALLOW_INSECURE_TLS=False
