# ==========================================
# CONFIGURACIÓN GLOBAL DEL CENTRO DE COMANDO
# ==========================================
# (Plantilla de Ejemplo)

# ------------------------------------------
# 1. Entorno Global
# ------------------------------------------
# Define el entorno de ejecución (development o production)
APP_ENV=development

# Tamaño del ThreadPool global para operaciones bloqueantes (Zeep, SQLite).
# Reducir en máquinas con poca RAM. Default: 64
THREAD_POOL_SIZE=64

# ------------------------------------------
# 2. Seguridad y Accesos
# ------------------------------------------
# --- Dashboard ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_esto_urgente

# --- Inspector de APIs (Anti-SSRF) ---
# Si INSPECTOR_ALLOW_INSECURE_TLS es False (Recomendado): Verifica estrictamente los certificados HTTPS.
# Si es True: Ignora la validez del certificado HTTPS (¡Vulnerable en producción!).
# Usar True SÓLO contra APIs locales en staging con certificados auto-firmados.
INSPECTOR_ALLOW_INSECURE_TLS=False

# ------------------------------------------
# 3. Integración Base: Recurso Confiable (RC)
# ------------------------------------------
RC_USERNAME=tu_usuario_real
RC_PASSWORD=tu_password_real
RC_ENDPOINT=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc

# Clave de cifrado simétrico AES (Fernet) para proteger el token en disco (Opcional pero recomendado).
# Si se deja vacío, el sistema generará una llave AES-128 dinámicamente derivando tu RC_PASSWORD
# a través de SHA-256 (para normalizar la longitud de tu contraseña a 32 bytes requeridos por Fernet).
# Puedes generar tu propia clave explícita ejecutando: 
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RC_TOKEN_ENC_KEY=

# ⚠️ IMPORTANTE (FAIL-SAFE): 
# RC_USE_MOCK controla si los datos realmente se envían a Recurso Confiable (RC).
# - Si es False (Producción): Ejecuta la petición SOAP real hacia RC.
# - Si es True (Solo Desarrollo): Se SIMULA el envío. Los datos se descartan sin enviarse.
# Para evitar pérdida silenciosa de datos, el sistema abortará si APP_ENV=production y RC_USE_MOCK=True.
RC_USE_MOCK=False

# ------------------------------------------
# 4. Proveedores PULL (CronJobs / Polling)
# ------------------------------------------
# (Los proveedores PULL dinámicos como Protrack ahora se configuran 100% 
# desde la interfaz web en la sección "Configuración Global" -> JSON fetch_config.
# Ya NO se guardan credenciales PULL en este archivo).

# ------------------------------------------
# 5. Proveedores PUSH (Webhooks)
# ------------------------------------------
# --- Schmitz ---
# Si se activa, Schmitz deberá enviar el Header: "x-api-key"
REQUIRE_SCHMITZ_AUTH=False
SCHMITZ_API_KEY=Schmitz_2026_UltraSecreta

# ------------------------------------------
# 6. Observabilidad (Logs)
# ------------------------------------------
# LOG_LEVEL controla la cantidad y detalle de información. Se puede cambiar en caliente (Hot-Reload).
# - DEBUG: Muestra tráfico de red (XMLs SOAP crudos), polling HTTP, etc.
# - INFO:  Resumen por lote de eventos, reinicios. Mantiene la consola limpia.
# - WARNING / ERROR / CRITICAL: Solo anomalías o fallos.
LOG_LEVEL=INFO

# Días que se conservarán los archivos de log históricos rotativos en la carpeta logs/.
LOG_RETENTION_DAYS=7
