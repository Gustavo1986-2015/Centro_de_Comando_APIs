# ==========================================

# CONFIGURACI횄혘횂혫N GLOBAL DEL CENTRO DE COMANDO

# (Plantilla de Ejemplo)

# ==========================================



# ------------------------------------------

# Entorno

# ------------------------------------------

APP_ENV=development



# ------------------------------------------

# 1. Credenciales de Destino (Recurso Confiable)

# ------------------------------------------

RC_USERNAME=tu_usuario_real

RC_PASSWORD=tu_password_real

RC_ENDPOINT=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc

# 횄짖횂혳횂혻횄짱횂쨍횂혧 IMPORTANTE (FAIL-SAFE): El valor por defecto es False.

# RC_USE_MOCK controla si los datos realmente se env횄혘횂짯an a Recurso Confiable (RC).

# - Si es False (Recomendado/Producci횄혘횂쨀n): El sistema ejecuta la petici횄혘횂쨀n SOAP real hacia RC.

#   (OJO: Tambi횄혘횂짤n puedes usar False en APP_ENV=development si quieres hacer pruebas de env횄혘횂짯o reales).

# - Si es True (Solo Desarrollo): El paso de env횄혘횂짯o a RC se SIMULA. Los eventos se reciben, 

#   se procesan, pero el env횄혘횂짯o final por SOAP se omite y se autogenera una respuesta de "횄혘횂짤xito" falsa.

#   Esto significa que los datos se consumen y se descartan; NUNCA llegar횄혘횂징n a los servidores de RC.

#   Para evitar p횄혘횂짤rdida silenciosa de datos, el sistema lanzar횄혘횂징 un RuntimeError si 

#   APP_ENV=production y RC_USE_MOCK=True.

RC_USE_MOCK=False



# ------------------------------------------

# 2. Configuraci횄혘횂쨀n de Nuevos Proveedores (Push vs Pull)

# ------------------------------------------

# NOTA ARQUITECT횄혘횂혫NICA: 

# Toda contrase횄혘횂짹a, token o secreto de las integraciones futuras DEBE colocarse aqu횄혘횂짯.



# --- INTEGRACIONES PULL (CronJobs) ---

# Si nosotros vamos a buscar los datos (Ej. Samsara, Geotab), 

# necesitamos sus tokens para autenticarnos en sus servidores.



# --- Protrack365 (GPS tracking PULL) ---

# URL base: http://api.protrack365.com (misma URL, credenciales distintas por entorno)

# Autenticaci횄혘횂쨀n: signature = md5(md5(password) + unix_time), token v횄혘횂징lido 2h

PROTRACK_ACCOUNT_TEST=

PROTRACK_PASSWORD_TEST=

PROTRACK_ACCOUNT_PROD=

PROTRACK_PASSWORD_PROD=

PROTRACK_POLL_INTERVAL_SEC=30



# --- INTEGRACIONES PUSH (Webhooks) ---

# Si ellos nos env횄혘횂짯an datos a nuestra URL (Ej. Schmitz), 

# nosotros debemos definir aqu횄혘횂짯 "Claves Secretas" que ellos 

# deber횄혘횂징n adjuntar en sus cabeceras (Headers) para dejarlos pasar,

# garantizando as횄혘횂짯 que nadie m횄혘횂징s pueda inyectar datos falsos.



# Si se activa, Schmitz deber횄혘횂징 enviar el Header: "x-api-key"

REQUIRE_SCHMITZ_AUTH=False

SCHMITZ_API_KEY=Schmitz_2026_UltraSecreta



# ------------------------------------------

# 3. Seguridad del Dashboard

# ------------------------------------------

DASHBOARD_USER=admin

DASHBOARD_PASSWORD=cambia_esto_urgente



# ------------------------------------------

# 4. Inspector de APIs (Anti-SSRF)

# ------------------------------------------

# 횄혗횂쩔Qu횄혘횂짤 hace esto? El Inspector act횄혘횂쨘a como un "Postman" interno. 

# Si INSPECTOR_ALLOW_INSECURE_TLS es False (Recomendado): El sistema VERIFICA estrictamente que los 

#   certificados HTTPS de las APIs externas sean v횄혘횂징lidos (Evita ataques Man-In-The-Middle donde un 

#   atacante podr횄혘횂짯a interceptar y robar tokens o contrase횄혘횂짹as en tr횄혘횂징nsito).

# Si es True: Se ignora la validez del certificado HTTPS (횄혗횂징Altamente vulnerable en producci횄혘횂쨀n!).

# 

# 횄혗횂쩔Cu횄혘횂징ndo ponerlo en True en tu entorno local? 

# S횄혘횂혫LO si est횄혘횂징s apuntando el Inspector hacia OTRA API que tienes corriendo en tu red local o 

# staging y que utiliza un certificado HTTPS auto-firmado ("self-signed" / inv횄혘횂징lido). 

# Si est횄혘횂징s probando contra APIs externas reales (ej. Protrack, Samsara), mantenlo en False SIEMPRE.

INSPECTOR_ALLOW_INSECURE_TLS=False



# Tama횄짹o del ThreadPool global para operaciones bloqueantes (Zeep, SQLite).

# Reducir en m횄징quinas con poca RAM. Default: 64

THREAD_POOL_SIZE=64


# ------------------------------------------
# 5. Configuraci처n de Logs (Observabilidad)
# ------------------------------------------
# LOG_LEVEL controla la cantidad y detalle de informaci처n que se imprime en consola y archivo.
# La consola utiliza 'colorlog' para una identificaci처n r찼pida de los eventos.
# Niveles soportados (de m찼s detallado a menos detallado):
# - DEBUG:    (Cyan) Muestra TODO. Tr찼fico de red (XMLs SOAP crudos de zeep), polling HTTP, estados de variables.
#             Recomendado: Solo para cazar bugs dif챠ciles. Ensucia mucho la consola.
# - INFO:     (Verde) Muestra el ciclo de vida del servidor, reinicios, y un resumen por lote de eventos
#             (cu찼ntos se enviaron, tiempo promedio, etc.). Mantiene la consola y el archivo limpios.
# - WARNING:  (Amarillo) Solo avisa de cosas anormales que el sistema pudo manejar (ej: un evento se omiti처, un reintento).
# - ERROR:    (Rojo) Solo muestra errores que causaron el fallo de un proceso o env챠o.
# - CRITICAL: (Rojo/Fondo Blanco) Solo bloqueos totales del sistema.
#
# 징Puedes cambiar LOG_LEVEL en caliente (Hot-Reload)! Si editas este archivo y lo guardas,
# el sistema detectar찼 el cambio en ~5 segundos y aplicar찼 el nuevo nivel sin reiniciar el servidor ni perder eventos.
LOG_LEVEL=INFO

# D챠as que se conservar찼n los archivos de log hist처ricos en la carpeta logs/
# El sistema rotar찼 los archivos a la medianoche (app.log.2026-06-25) y borrar찼 autom찼ticamente
# los archivos m찼s viejos que la cantidad de d챠as especificada aqu챠.
LOG_RETENTION_DAYS=7

# ------------------------------------------
# 6. Testing local (Opcional)
